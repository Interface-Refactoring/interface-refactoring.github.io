@startuml

class API {
}
note left: <b>API Refactorings:</b>\n • Tighten Evolution Strategy \n • Relax Evolution Strategy

class Endpoint {
 Address location
 APIPattern role
}
note left: <b>Endpoint Refactorings:</b>\n • Rename Endpoint \n • Merge Endpoints \n • Segregate Commands from Queries

class "Communication Participant" as CommunicationParticipant {
}

CommunicationParticipant -left-> Endpoint

class "API Client" as APIClient {
}
note left: <b>Client Refactorings:</b>\n — Distribute Application Frontend


class "API Provider" as APIProvider {
}
note bottom: <b>Backend Refactorings:</b>\n — Split Application Backend Logic \n — Split Application Backend Persistence


APIClient -[hidden]right-> APIProvider

APIClient -up-|> CommunicationParticipant
APIProvider -up-|> CommunicationParticipant

note "<b>Evolution Refactorings:</b>\n • Introduce Version Identifier\n • Introduce Version Mediator" as EvolutionRefactoringNote

class Operation {
 String name
 APIPattern responsibility
}
note left: <b>Operation Refactorings:</b>\n • Extract Operation \n • Move Operation \n • Rename Operation \n • Split Operation \n • Merge Operations 

EvolutionRefactoringNote -left- Endpoint

class "Response Message Payload" as ResponseMessagePayload {
  KeyValuePairs protocolHeaders
  RepresentationElements requestPayload
}
note bottom: <b>Message Refactorings 1/2:</b>\n • Introduce Data Transfer Object \n • Extract Information Holder \n • Inline Information Holder \n • Introduce Pagination \n • Rename Representation Element

class "Request Message Payload" as RequestMessagePayload {
  KeyValuePairs protocolHeaders
  RepresentationElements responsePayload
}
note bottom: <b>Message Refactorings 2/2:</b>\n • Add Wish List \n • Add Wish Template \n • Bundle Requests \n • Encapsulate Context Representation \n • Make Request Conditional

API *-- Endpoint
Endpoint *-- Operation 
Operation *-- RequestMessagePayload 
Operation *-- ResponseMessagePayload
' RequestMessage *-- InParameters
' ResponseMessage*-- OutParameters

@enduml